# OpenRouter API Key (required)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Comma-separated list of OpenRouter model IDs to test
# Default models match the Qwen3 models from the research proposal
MODELS=qwen/qwen3-vl-8b-instruct,qwen/qwen3-vl-8b-thinking,qwen/qwen3-vl-30b-a3b-instruct,qwen/qwen3-vl-30b-a3b-thinking,qwen/qwen3-vl-235b-a22b-instruct,qwen/qwen3-vl-235b-a22b-thinking

# Model parameters (controlled variables)
TEMPERATURE=0
SEED=42
TOP_P=1
TOP_K=0
REPETITION_PENALTY=1
FREQUENCY_PENALTY=0
PRESENCE_PENALTY=0
MAX_TOKENS=200
